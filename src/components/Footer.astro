---
import { Linkedin, Github } from '@lucide/astro';
import type { Translations } from '../i18n/index';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<footer class="border-t border-[#0F0F0F]/[.08] py-8">
  <div class="max-w-5xl mx-auto px-6 flex items-center justify-between gap-4 flex-wrap">
    <span class="text-sm text-[#0F0F0F]/50">
      {t.footer.copy}
    </span>
    <div class="flex items-center gap-4">
      <a
        href="https://linkedin.com/in/benjamin-bellantonio"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="text-[#0F0F0F]/40 hover:text-blue-600 transition-colors"
      >
        <Linkedin size={18} />
      </a>
      <a
        href="https://github.com/benjbdev"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="text-[#0F0F0F]/40 hover:text-[#0F0F0F] transition-colors"
      >
        <Github size={18} />
      </a>
    </div>
  </div>
</footer>
