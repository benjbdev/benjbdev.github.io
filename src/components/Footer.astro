---
import { Linkedin, Github } from '@lucide/astro';
import type { Translations } from '../i18n/index';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<footer class="py-8 bg-[#F8F8F8] dark:bg-[#0A0A0A]">
  <div class="max-w-[1024px] mx-auto px-6">
    <div class="flex items-center justify-between gap-4 flex-wrap">
      <span class="font-sans text-xs text-[#888]">
        {t.footer.copy}
      </span>
      <div class="flex items-center gap-4">
        <a
          href="https://linkedin.com/in/benjamin-bellantonio"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="font-sans text-xs text-[#888] hover:underline transition-colors"
        >
          <Linkedin size={16} />
        </a>
        <a
          href="https://github.com/benjbdev"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="font-sans text-xs text-[#888] hover:underline transition-colors"
        >
          <Github size={16} />
        </a>
      </div>
    </div>
  </div>
</footer>
