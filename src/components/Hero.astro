---
import type { Translations } from '../i18n/index';

interface Props {
  lang: 'en' | 'fr';
  t: Translations;
}

const { t } = Astro.props;
---

<section id="hero" class="min-h-screen flex flex-col justify-center">
  <div class="max-w-[1024px] mx-auto px-6 py-24 w-full">
    <h1 class="font-sans font-bold text-[4em] text-[#1a1a1a] dark:text-[#f0f0ec] leading-[1.1] tracking-tight mb-8">
      Hey, I'm Benjamin.<br />{t.hero.tagline}
    </h1>

    <div>
      <p class="font-mono text-sm leading-relaxed text-[#555] dark:text-[#999] mb-8">
        {t.hero.subtitle}
      </p>
      <div class="flex flex-wrap gap-4 items-center">
        <a
          href="#services"
          class="font-mono text-sm border border-[#1a1a1a] dark:border-[#f0f0ec] text-[#1a1a1a] dark:text-[#f0f0ec] px-4 py-2 rounded-md hover:bg-[#1a1a1a] dark:hover:bg-[#f0f0ec] hover:text-[#f5f5f0] dark:hover:text-[#1a1a1a] transition-colors"
        >
          {t.hero.cta1}
        </a>
        <a
          href="#contact"
          class="font-mono text-sm text-[#1a1a1a] dark:text-[#f0f0ec] underline underline-offset-4 hover:no-underline transition-all"
        >
          {t.hero.cta2}
        </a>
      </div>
    </div>
  </div>
</section>
