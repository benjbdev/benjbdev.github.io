---
import type { Translations } from '../i18n/index';

interface Props {
  lang: 'en' | 'fr';
  t: Translations;
}

const { t } = Astro.props;
---

<section id="hero" class="min-h-screen flex flex-col justify-center">
  <div class="max-w-[1024px] mx-auto px-6 py-24 w-full">
    <h1 class="font-sans font-bold text-[2.5em] sm:text-[4em] text-[#1a1a1a] leading-[1.1] tracking-tight mb-8">
      {t.hero.greeting}<br /><span set:html={t.hero.tagline} />
    </h1>

    <div>
      <p class="font-mono text-sm leading-relaxed text-[#555] mb-8">
        {t.hero.subtitle}
      </p>
      <div class="flex flex-wrap gap-4 items-center">
        <a
          href="#services"
          class="font-mono text-sm border border-[#1a1a1a] text-[#1a1a1a] px-4 py-2 rounded-md hover:bg-[#1a1a1a] hover:text-[#f5f5f0] transition-colors"
        >
          {t.hero.cta1}
        </a>
        <a
          href="#contact"
          class="font-mono text-sm text-[#1a1a1a] underline underline-offset-4 hover:no-underline transition-all"
        >
          {t.hero.cta2}
        </a>
      </div>
    </div>
  </div>
</section>
