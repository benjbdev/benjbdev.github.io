---
import type { Translations } from '../i18n/index';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="about" class="py-24 bg-white scroll-mt-[78px]">
  <div class="max-w-[1024px] mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-[220px_1fr] gap-8">
      <div class="font-sans text-xl font-bold uppercase tracking-wide text-[#1a1a1a]">{t.about.label}</div>
      <div>
        <p class="font-mono text-base leading-relaxed text-[#555] mb-8 fade-in-hidden">
          <span set:html={t.about.bio} />
        </p>

        <h3 class="font-sans text-base font-semibold mb-3 fade-in-hidden">
          {t.about.whenTitle}
        </h3>
        <ul class="space-y-2 mb-10">
          {t.about.whenList.map((item) => (
            <li class="border-l-2 border-[#1a1a1a] pl-3 py-1 font-mono text-base text-[#555] leading-relaxed fade-in-hidden">
              {item}
            </li>
          ))}
        </ul>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 fade-in-hidden">
          {t.about.stats.map((stat) => (
            <div>
              <div class="font-sans font-bold text-3xl text-[#1a1a1a]">
                {stat.value}
              </div>
              <div class="font-mono text-sm text-[#888] mt-1">
                {stat.label}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
