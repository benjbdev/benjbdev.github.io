---
import { Menu, Languages } from '@lucide/astro';
import type { Translations } from '../i18n/index';

interface Props {
  lang: 'en' | 'fr';
  t: Translations;
}

const { lang, t } = Astro.props;
const altLang = lang === 'en' ? 'fr' : 'en';
---

<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 border-b border-transparent bg-[#f5f5f0]/90 backdrop-blur-sm border-[#e0e0e0]">
  <div class="max-w-[1024px] mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href="#" class="font-script text-[46px] font-bold leading-none hover:opacity-70 transition-opacity">
      {t.nav.logo}
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-6">
      <a href="#about" class="font-sans text-sm text-[#888] hover:text-[#1a1a1a] hover:underline transition-colors">{t.nav.about}</a>
      <a href="#services" class="font-sans text-sm text-[#888] hover:text-[#1a1a1a] hover:underline transition-colors">{t.nav.services}</a>
      <a href="#contact" class="font-sans text-sm text-[#888] hover:text-[#1a1a1a] hover:underline transition-colors">{t.nav.contact}</a>
      <a
        href={`/${altLang}/`}
        data-lang={altLang}
        aria-label={`${t.nav.switchLang} ${altLang}`}
        class="flex items-center gap-1.5 font-sans text-sm text-[#888] hover:text-[#1a1a1a] transition-colors border border-[#e0e0e0] rounded-md px-2 py-1"
      >
        <Languages size={14} />
        <span class="uppercase">{altLang}</span>
      </a>
    </div>

    <!-- Mobile: lang + hamburger -->
    <div class="flex md:hidden items-center gap-3">
      <a
        href={`/${altLang}/`}
        data-lang={altLang}
        aria-label={`${t.nav.switchLang} ${altLang}`}
        class="flex items-center gap-1 font-sans text-sm text-[#888] border border-[#e0e0e0] rounded-md px-2 py-1"
      >
        <Languages size={13} />
        <span class="uppercase">{altLang}</span>
      </a>
      <button id="menu-toggle" aria-label={t.nav.openMenu} class="text-[#888]">
        <Menu size={18} />
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="md:hidden">
    <div id="mobile-menu" class="hidden border-t border-b border-[#e0e0e0] px-6 py-4 flex flex-col gap-4 bg-[#f5f5f0]">
      <a href="#about" class="font-sans text-sm text-[#888]">{t.nav.about}</a>
      <a href="#services" class="font-sans text-sm text-[#888]">{t.nav.services}</a>
      <a href="#contact" class="font-sans text-sm text-[#888]">{t.nav.contact}</a>
    </div>
  </div>
</nav>

<script is:inline>
  // Sticky nav: transparent at top, opaque on scroll
  var nav = document.getElementById('main-nav');
  var SCROLLED_ADD = ['bg-[#f5f5f0]/90', 'backdrop-blur-sm', 'border-[#e0e0e0]'];
  var SCROLLED_REMOVE = ['border-transparent'];
  function updateNav() {
    if (window.scrollY > 40) {
      SCROLLED_ADD.forEach(function(c) { nav.classList.add(c); });
      SCROLLED_REMOVE.forEach(function(c) { nav.classList.remove(c); });
    } else {
      SCROLLED_ADD.forEach(function(c) { nav.classList.remove(c); });
      SCROLLED_REMOVE.forEach(function(c) { nav.classList.add(c); });
    }
  }
  updateNav();
  window.addEventListener('scroll', updateNav, { passive: true });

  // Language preference persistence
  document.querySelectorAll('[data-lang]').forEach(function (el) {
    el.addEventListener('click', function () {
      localStorage.setItem('lang', el.getAttribute('data-lang'));
    });
  });

  // Mobile menu toggle
  var menuToggle = document.getElementById('menu-toggle');
  var mobileMenu = document.getElementById('mobile-menu');
  if (menuToggle && mobileMenu) {
    menuToggle.addEventListener('click', function () {
      mobileMenu.classList.toggle('hidden');
    });
    mobileMenu.querySelectorAll('a').forEach(function (link) {
      link.addEventListener('click', function () {
        mobileMenu.classList.add('hidden');
      });
    });
  }
</script>
