---
import type { Translations } from '../i18n/index';

interface Props {
  lang: 'en' | 'fr';
  t: Translations;
}

const { t } = Astro.props;
const formspreeId = import.meta.env.PUBLIC_FORMSPREE_ID;
const bookCallUrl = import.meta.env.PUBLIC_BOOK_CALL_URL;
---

<section id="contact" class="py-24 border-t border-[#0F0F0F]/[.08]">
  <div class="max-w-5xl mx-auto px-6">
    <p class="font-mono text-xs uppercase tracking-widest text-blue-600 mb-8">
      {t.contact.label}
    </p>

    <p class="text-base leading-relaxed text-[#0F0F0F]/70 max-w-2xl mb-12">
      {t.contact.intro}
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Book a call -->
      <div class="p-6 border border-[#0F0F0F]/[.08] bg-[#F8F8F8] flex flex-col justify-between">
        <div>
          <h3 class="font-semibold text-[#0F0F0F] mb-2">
            {t.contact.bookTitle}
          </h3>
          <p class="text-sm text-[#0F0F0F]/60 mb-6">
            {t.contact.bookSubtext}
          </p>
        </div>
        <a
          href={bookCallUrl || '#'}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block bg-blue-600 text-white px-5 py-2.5 text-sm font-medium hover:bg-blue-700 transition-colors text-center"
        >
          {t.contact.bookTitle}
        </a>
      </div>

      <!-- Contact form -->
      <div>
        <form
          id="contact-form"
          action={`https://formspree.io/f/${formspreeId}`}
          method="POST"
          class="flex flex-col gap-4"
        >
          <div>
            <label for="name" class="block text-xs text-[#0F0F0F]/60 mb-1">
              {t.contact.formName} *
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full bg-transparent border border-[#0F0F0F]/[.15] px-3 py-2 text-sm text-[#0F0F0F] placeholder-[#0F0F0F]/30 focus:outline-none focus:border-blue-600 transition-colors"
            />
          </div>

          <div>
            <label for="email" class="block text-xs text-[#0F0F0F]/60 mb-1">
              {t.contact.formEmail} *
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full bg-transparent border border-[#0F0F0F]/[.15] px-3 py-2 text-sm text-[#0F0F0F] placeholder-[#0F0F0F]/30 focus:outline-none focus:border-blue-600 transition-colors"
            />
          </div>

          <div>
            <label for="company" class="block text-xs text-[#0F0F0F]/60 mb-1">
              {t.contact.formCompany}
            </label>
            <input
              type="text"
              id="company"
              name="company"
              class="w-full bg-transparent border border-[#0F0F0F]/[.15] px-3 py-2 text-sm text-[#0F0F0F] placeholder-[#0F0F0F]/30 focus:outline-none focus:border-blue-600 transition-colors"
            />
          </div>

          <div>
            <label for="message" class="block text-xs text-[#0F0F0F]/60 mb-1">
              {t.contact.formMessage} *
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows={4}
              class="w-full bg-transparent border border-[#0F0F0F]/[.15] px-3 py-2 text-sm text-[#0F0F0F] placeholder-[#0F0F0F]/30 focus:outline-none focus:border-blue-600 transition-colors resize-none"
            ></textarea>
          </div>

          <div
            id="form-error"
            class="hidden text-sm text-red-600 bg-red-50 border border-red-200 px-3 py-2"
          >
            {t.contact.formError}
          </div>

          <button
            id="submit-btn"
            type="submit"
            class="bg-blue-600 text-white px-5 py-2.5 text-sm font-medium hover:bg-blue-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
          >
            {t.contact.formSubmit}
          </button>
        </form>

        <div id="form-success" class="hidden text-sm text-green-700 bg-green-50 border border-green-200 px-4 py-3">
          {t.contact.formSuccess}
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var form = document.getElementById('contact-form');
    if (!form) return;

    form.addEventListener('submit', async function (e) {
      e.preventDefault();

      var submitBtn = document.getElementById('submit-btn');
      var formError = document.getElementById('form-error');
      var formSuccess = document.getElementById('form-success');
      var originalText = submitBtn.textContent;

      formError.classList.add('hidden');

      var nameEl = form.elements.namedItem('name');
      var emailEl = form.elements.namedItem('email');
      var messageEl = form.elements.namedItem('message');
      var companyEl = form.elements.namedItem('company');

      if (!nameEl.value.trim() || !emailEl.value.trim() || !messageEl.value.trim()) {
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = '...';

      try {
        var resp = await fetch(form.action, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Accept: 'application/json',
          },
          body: JSON.stringify({
            name: nameEl.value,
            email: emailEl.value,
            company: companyEl ? companyEl.value : '',
            message: messageEl.value,
          }),
        });

        if (resp.ok) {
          form.classList.add('hidden');
          formSuccess.classList.remove('hidden');
        } else {
          formError.classList.remove('hidden');
          submitBtn.disabled = false;
          submitBtn.textContent = originalText;
        }
      } catch (err) {
        formError.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
      }
    });
  })();
</script>
