---
import type { Translations } from '../i18n/index';

interface Props {
  lang: 'en' | 'fr';
  t: Translations;
}

const { t } = Astro.props;
const formspreeId = import.meta.env.PUBLIC_FORMSPREE_ID;
const bookCallUrl = import.meta.env.PUBLIC_BOOK_CALL_URL;
---

<section id="contact" class="py-24 bg-white dark:bg-[#141414]">
  <div class="max-w-[1024px] mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-[220px_1fr] gap-8">
      <div class="font-sans text-xl font-bold uppercase tracking-wide text-[#1a1a1a] dark:text-[#f0f0ec]">{t.contact.label}</div>
      <div>
        <p class="font-mono text-base leading-relaxed text-[#555] dark:text-[#999] mb-10 fade-in-hidden">
          {t.contact.intro}
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 fade-in-hidden">
          <!-- Book a call -->
          <div>
            <p class="font-sans text-xl font-bold uppercase tracking-wide text-[#1a1a1a] dark:text-[#f0f0ec] mb-4">{t.contact.bookTitle}</p>
            <p class="font-mono text-sm text-[#888] mb-4">{t.contact.bookSubtext}</p>
            <a
              href={bookCallUrl || '#'}
              target="_blank"
              rel="noopener noreferrer"
              class="font-mono text-sm border border-[#1a1a1a] dark:border-[#f0f0ec] text-[#1a1a1a] dark:text-[#f0f0ec] px-4 py-2 rounded-md inline-block hover:bg-[#1a1a1a] dark:hover:bg-[#f0f0ec] hover:text-[#f5f5f0] dark:hover:text-[#1a1a1a] transition-colors"
            >
              {t.contact.bookTitle} →
            </a>
          </div>

          <!-- Contact form -->
          <div>
            <p class="font-sans text-xl font-bold uppercase tracking-wide text-[#1a1a1a] dark:text-[#f0f0ec] mb-4">{t.contact.formTitle}</p>
        <form
          id="contact-form"
          action={`https://formspree.io/f/${formspreeId}`}
          method="POST"
          class="flex flex-col gap-6 fade-in-hidden"
        >
          <div>
            <label for="name" class="block font-mono text-sm text-[#888] mb-1">
              {t.contact.formName} *
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full bg-transparent border-0 border-b border-[#e0e0e0] dark:border-[#333] rounded-none font-mono text-sm text-[#1a1a1a] dark:text-[#f0f0ec] focus:border-[#1a1a1a] dark:focus:border-[#f0f0ec] focus:outline-none py-2 transition-colors"
            />
          </div>

          <div>
            <label for="email" class="block font-mono text-sm text-[#888] mb-1">
              {t.contact.formEmail} *
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full bg-transparent border-0 border-b border-[#e0e0e0] dark:border-[#333] rounded-none font-mono text-sm text-[#1a1a1a] dark:text-[#f0f0ec] focus:border-[#1a1a1a] dark:focus:border-[#f0f0ec] focus:outline-none py-2 transition-colors"
            />
          </div>

          <div>
            <label for="company" class="block font-mono text-sm text-[#888] mb-1">
              {t.contact.formCompany}
            </label>
            <input
              type="text"
              id="company"
              name="company"
              class="w-full bg-transparent border-0 border-b border-[#e0e0e0] dark:border-[#333] rounded-none font-mono text-sm text-[#1a1a1a] dark:text-[#f0f0ec] focus:border-[#1a1a1a] dark:focus:border-[#f0f0ec] focus:outline-none py-2 transition-colors"
            />
          </div>

          <div>
            <label for="message" class="block font-mono text-sm text-[#888] mb-1">
              {t.contact.formMessage} *
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows={4}
              class="w-full bg-transparent border-0 border-b border-[#e0e0e0] dark:border-[#333] rounded-none font-mono text-sm text-[#1a1a1a] dark:text-[#f0f0ec] focus:border-[#1a1a1a] dark:focus:border-[#f0f0ec] focus:outline-none py-2 transition-colors resize-none"
            ></textarea>
          </div>

          <div
            id="form-error"
            class="hidden font-mono text-sm text-[#555] dark:text-[#999] border-l-2 border-[#555] dark:border-[#999] pl-3 py-1"
          >
            {t.contact.formError}
          </div>

          <div>
            <button
              id="submit-btn"
              type="submit"
              class="font-mono text-sm border border-[#1a1a1a] dark:border-[#f0f0ec] text-[#1a1a1a] dark:text-[#f0f0ec] px-4 py-2 rounded-md hover:bg-[#1a1a1a] dark:hover:bg-[#f0f0ec] hover:text-[#f5f5f0] dark:hover:text-[#1a1a1a] transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
            >
              {t.contact.formSubmit}
            </button>
          </div>
        </form>

        <div id="form-success" class="hidden font-mono text-sm text-[#555] dark:text-[#999] border-l-2 border-[#1a1a1a] dark:border-[#f0f0ec] pl-3 py-1">
          {t.contact.formSuccess}
        </div>
          </div> <!-- end form column -->
        </div> <!-- end 2-col grid -->
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var form = document.getElementById('contact-form');
    if (!form) return;

    form.addEventListener('submit', async function (e) {
      e.preventDefault();

      var submitBtn = document.getElementById('submit-btn');
      var formError = document.getElementById('form-error');
      var formSuccess = document.getElementById('form-success');
      var originalText = submitBtn.textContent;

      formError.classList.add('hidden');

      var nameEl = form.elements.namedItem('name');
      var emailEl = form.elements.namedItem('email');
      var messageEl = form.elements.namedItem('message');
      var companyEl = form.elements.namedItem('company');

      if (!nameEl.value.trim() || !emailEl.value.trim() || !messageEl.value.trim()) {
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = '...';

      try {
        var resp = await fetch(form.action, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Accept: 'application/json',
          },
          body: JSON.stringify({
            name: nameEl.value,
            email: emailEl.value,
            company: companyEl ? companyEl.value : '',
            message: messageEl.value,
          }),
        });

        if (resp.ok) {
          form.classList.add('hidden');
          formSuccess.classList.remove('hidden');
        } else {
          formError.classList.remove('hidden');
          submitBtn.disabled = false;
          submitBtn.textContent = originalText;
        }
      } catch (err) {
        formError.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
      }
    });
  })();
</script>
