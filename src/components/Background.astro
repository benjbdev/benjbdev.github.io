---
import type { Translations } from '../i18n/index';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="background" class="py-24 border-t border-[#0F0F0F]/[.08]">
  <div class="max-w-5xl mx-auto px-6">
    <p class="font-mono text-xs uppercase tracking-widest text-blue-600 mb-8">
      {t.background.label}
    </p>

    <p class="text-base leading-relaxed text-[#0F0F0F]/80 max-w-2xl mb-8">
      {t.background.bio}
    </p>

    <a
      href="https://linkedin.com/in/benjamin-bellantonio"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center text-sm text-blue-600 hover:underline font-medium"
    >
      {t.background.cta}
    </a>
  </div>
</section>
