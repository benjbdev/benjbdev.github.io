---
import type { Translations } from '../i18n/index';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="background" class="py-24 bg-white dark:bg-[#141414]">
  <div class="max-w-[1024px] mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-[220px_1fr] gap-8">
      <div class="font-sans text-xl font-bold uppercase tracking-wide text-[#1a1a1a] dark:text-[#f0f0ec]">{t.background.label}</div>
      <div class="fade-in-hidden">
        <p class="font-mono text-base leading-relaxed text-[#555] dark:text-[#999] mb-6">
          {t.background.bio}
        </p>
        <a
          href="https://linkedin.com/in/benjamin-bellantonio"
          target="_blank"
          rel="noopener noreferrer"
          class="font-mono text-base text-[#1a1a1a] dark:text-[#f0f0ec] hover:underline"
        >
          {t.background.cta}
        </a>
      </div>
    </div>
  </div>
</section>
